# Bot
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
GUILD_ID=
VERIFIED_ROLE_ID=               # bootstrap default; overridable at runtime with /config verified
LOG_CHANNEL_ID=                 # optional; verification log channel. Overridable with /config logs
# Web (Discord OAuth)
DISCORD_CLIENT_SECRET=
WEB_BASE_URL=https://cfg.ly.ax
OAUTH_REDIRECT_URI=https://cfg.ly.ax/auth/callback   # register in Discord dev portal; discordFor() derives from request origin so localhost also works
DASHBOARD_SESSION_SECRET=        # openssl rand -hex 32  (HMAC for state/session)
# Fraud APIs
PROXYCHECK_API_KEY=              # proxycheck.io — primary VPN/proxy/Tor detector (free 1000/day)
IPINFO_TOKEN=                    # ipinfo.io Lite API token — datacenter/ASN detection (free)
PROXYCHECK_RISK_THRESHOLD=75     # ProxyCheck risk score 0-100 at/above which to flag
IPINFO_BLOCK_DATACENTER=true     # true | false — flag hosting/datacenter ASNs via ipinfo
FAIL_MODE=open                   # open | closed — behaviour when BOTH providers fail
BLOCK_TTL=3600                   # seconds a VPN/proxy block lasts (default 1h — a light cooldown)
# IP capture
# If the site is proxied through Cloudflare (Cloudflare -> nginx -> app), set
# CLIENT_IP_HEADER=cf-connecting-ip — Cloudflare carries the real visitor IP in
# that header. Without it the app would record Cloudflare's edge IP (AS13335).
CLIENT_IP_HEADER=cf-connecting-ip
# Fallback when CLIENT_IP_HEADER is unset/absent (plain nginx, no Cloudflare):
ADDRESS_HEADER=X-Forwarded-For   # adapter-node getClientAddress() reads this header
XFF_DEPTH=1                      # trusted proxy hops in the X-Forwarded-For chain (nginx only = 1)
# Multi-account (same-IP alt) detection
MULTI_ACCOUNT_MODE=block         # block | flag | off
MULTI_ACCOUNT_MAX_PER_IP=1       # distinct live members allowed per IP before blocking
MULTI_ACCOUNT_IP_WINDOW_DAYS=90  # ignore IP matches older than this (IP churn)
MULTI_ACCOUNT_BLOCK_TTL=86400    # seconds; Redis block TTL for a multi_account hit
MULTI_ACCOUNT_LENIENT_CONN_TYPES=mobile,corporate,education   # downgrade block->flag on shared-NAT
MULTI_ACCOUNT_REVEAL_USERNAME=true   # true | masked | false
# Privacy
IP_HASH_SALT=
# Infra (shared)
MONGODB_URI=mongodb://localhost:27017/cfg-verify
REDIS_URL=redis://localhost:6379
LOG_LEVEL=INFO
