{
  "name": "cfg-bot",
  "version": "1.0.0",
  "description": "CFG (Control Flow Guard) — single-guild Discord VPN-verification bot",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.11.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch source/index.ts",
    "deploy": "tsx source/deploy-commands.ts",
    "clear-commands": "tsx source/clear-commands.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint source",
    "lint:fix": "eslint source --fix",
    "format": "prettier --write source",
    "format:check": "prettier --check source",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "discord",
    "discord.js",
    "bot",
    "verification",
    "vpn"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.2",
    "mongoose": "^8.14.2",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
